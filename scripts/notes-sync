#!/usr/bin/env bash
# notes-sync — commit and push any changes in the notes repo

REPO="/home/luke/notes"

cd "$REPO" || exit 1

# Pull first to avoid conflicts with remote pushes
git pull --rebase --quiet

# If nothing changed locally, exit
if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
  exit 0
fi

git add -A
git commit -m "sync: $(date '+%Y-%m-%d %H:%M')"
git push
