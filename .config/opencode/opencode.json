{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.4",
  "small_model": "github-copilot/gpt-5-mini",
  "plugin": [
    "oh-my-opencode-slim@1.0.0",
    "@tarquinen/opencode-dcp@3.1.9"
  ],
  "instructions": [
    "rules.md"
  ],
  "permission": {
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "external_directory": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "cat .env*": "deny",
      "cat *.pem": "deny",
      "cat *.key": "deny",
      "head *": "allow",
      "head .env*": "deny",
      "tail *": "allow",
      "tail .env*": "deny",
      "wc *": "allow",
      "grep *": "allow",
      "which *": "allow",
      "echo *": "ask",
      "mkdir *": "ask",
      "touch *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      "date": "allow",
      "uname *": "allow",
      "cp *": "ask",
      "mv *": "ask",
      "rm *": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "ask",
      "git branch --list *": "allow",
      "git branch -a": "allow",
      "git rev-parse *": "allow",
      "git remote -v": "allow",
      "git remote show *": "allow",
      "git ls-files *": "allow",
      "git fetch *": "allow",
      "git stash list *": "allow",
      "git describe *": "allow",
      "git shortlog *": "allow",
      "git blame *": "allow",
      "git grep *": "allow",
      "git -C * status *": "allow",
      "git -C * diff *": "allow",
      "git -C * log *": "allow",
      "git -C * show *": "allow",
      "git -C * branch *": "ask",
      "git -C * branch --list *": "allow",
      "git -C * branch -a": "allow",
      "git -C * rev-parse *": "allow",
      "git -C * ls-files *": "allow",
      "git -C * remote -v": "allow",
      "git --git-dir=* --work-tree=* status *": "allow",
      "git --git-dir=* --work-tree=* diff *": "allow",
      "git --git-dir=* --work-tree=* log *": "allow",
      "git --git-dir=* --work-tree=* show *": "allow",
      "git --git-dir=* --work-tree=* branch *": "ask",
      "git --git-dir=* --work-tree=* branch --list *": "allow",
      "git --git-dir=* --work-tree=* branch -a": "allow",
      "git --git-dir=* --work-tree=* rev-parse *": "allow",
      "git --git-dir=* --work-tree=* ls-files *": "allow",
      "git -c *": "ask",
      "git add *": "ask",
      "git commit *": "ask",
      "git push --force-with-lease *": "ask",
      "git push --force *": "deny",
      "git push * --force*": "deny",
      "git push *": "ask",
      "git pull *": "ask",
      "git switch *": "ask",
      "git checkout *": "ask",
      "git merge *": "ask",
      "git rebase *": "ask",
      "git cherry-pick *": "ask",
      "git stash *": "ask",
      "git restore *": "ask",
      "git tag *": "ask",
      "git config *": "deny",
      "git reset *": "deny",
      "git clean *": "deny",
      "go test": "allow",
      "go test *": "allow",
      "go build *": "allow",
      "go vet *": "allow",
      "go fmt *": "allow",
      "go env": "allow",
      "go env -json": "allow",
      "go list .": "allow",
      "go list ./...": "allow",
      "go list -json .": "allow",
      "go list -json ./...": "allow",
      "gofmt": "allow",
      "gofmt *": "allow",
      "go mod tidy": "ask",
      "go get *": "ask",
      "go run *": "ask",
      "go generate *": "ask",
      "pytest *": "allow",
      "cargo test *": "allow",
      "cargo build *": "allow",
      "cargo check *": "allow",
      "npm test": "allow",
      "pnpm test": "allow",
      "npm install *": "ask",
      "pnpm add *": "ask",
      "yarn add *": "ask",
      "pip install *": "ask",
      "uv pip *": "ask",
      "cargo add *": "ask",
      "brew *": "ask",
      "apt *": "ask",
      "docker *": "ask",
      "make *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "node *": "ask",
      "python *": "ask",
      "python3 *": "ask",
      "ruby *": "ask",
      "npx *": "ask",
      "chmod *": "deny",
      "chown *": "deny",
      "sh *": "deny",
      "bash *": "deny",
      "eval *": "deny",
      "sudo *": "deny"
    }
  }
}
