{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.4",
  "small_model": "github-copilot/gpt-5-mini",
  "plugin": [
    "oh-my-opencode-slim@0.9.2",
    "@tarquinen/opencode-dcp@3.1.8"
  ],
  "instructions": [
    "rules.md"
  ],
  "permission": {
    "read": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "edit": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "external_directory": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "cat .env*": "deny",
      "cat *.pem": "deny",
      "cat *.key": "deny",
      "head *": "allow",
      "head .env*": "deny",
      "tail *": "allow",
      "tail .env*": "deny",
      "wc *": "allow",
      "grep *": "allow",
      "which *": "allow",
      "echo *": "ask",
      "mkdir *": "ask",
      "touch *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      "date": "allow",
      "uname *": "allow",
      "cp *": "ask",
      "mv *": "ask",
      "rm *": "ask",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git rev-parse *": "allow",
      "git remote -v": "allow",
      "git ls-files *": "allow",
      "git fetch *": "allow",
      "git add *": "ask",
      "git commit *": "ask",
      "git push --force-with-lease *": "ask",
      "git push --force *": "deny",
      "git push * --force*": "deny",
      "git push *": "ask",
      "git pull *": "ask",
      "git switch *": "ask",
      "git checkout *": "ask",
      "git merge *": "ask",
      "git rebase *": "ask",
      "git cherry-pick *": "ask",
      "git stash *": "ask",
      "git restore *": "ask",
      "git tag *": "ask",
      "git config *": "deny",
      "git reset *": "deny",
      "git clean *": "deny",
      "go test": "allow",
      "go test *": "allow",
      "go build *": "allow",
      "go vet *": "allow",
      "go fmt *": "allow",
      "go mod tidy": "ask",
      "go get *": "ask",
      "go run *": "ask",
      "go generate *": "ask",
      "pytest *": "allow",
      "cargo test *": "allow",
      "cargo build *": "allow",
      "cargo check *": "allow",
      "npm test": "allow",
      "pnpm test": "allow",
      "npm install *": "ask",
      "pnpm add *": "ask",
      "yarn add *": "ask",
      "pip install *": "ask",
      "uv pip *": "ask",
      "cargo add *": "ask",
      "brew *": "ask",
      "apt *": "ask",
      "docker *": "ask",
      "make *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "node *": "ask",
      "python *": "ask",
      "python3 *": "ask",
      "ruby *": "ask",
      "npx *": "ask",
      "chmod *": "deny",
      "chown *": "deny",
      "sh *": "deny",
      "bash *": "deny",
      "eval *": "deny",
      "sudo *": "deny"
    }
  }
}
